  "auth": {
    "enabled": true,
    "provider": "dingtalk",
    "dingtalk_app_key": "dingxxxx",
    "dingtalk_app_secret": "your-dingtalk-app-secret",
    "dingtalk_redirect_uri": "http://your-host/api/auth/dingtalk/callback",
